---
import { getCollection, render } from "astro:content";
import Markdown from "@components/misc/Markdown.astro";
import Giscus from "../components/Giscus.astro";
import I18nKey from "../i18n/i18nKey";
import { i18n } from "../i18n/translation";
import MainGridLayout from "../layouts/MainGridLayout.astro";

export async function getStaticPaths() {
	const excludeList = ["about", "friends"];
	const specEntries = await getCollection("pages");
	const filteredEntries = specEntries.filter(
		(entry) => !excludeList.includes(entry.slug),
	);

	return filteredEntries.map((entry) => ({
		params: { spec: entry.slug },
		props: { entry },
	}));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const i18nKey = I18nKey[entry.slug as keyof typeof I18nKey];
const title = i18nKey ? i18n(i18nKey) : entry.slug;
const description = title;
---

<MainGridLayout title={title} description={description}>
    <div class="flex w-full rounded-[var(--radius-large)] overflow-hidden relative min-h-32">
        <div class="card-base z-10 px-9 py-6 relative w-full ">
            <Markdown class="mt-2">
                <Content />
            </Markdown>
            <!-- Giscus 评论组件 -->
            <Giscus class="onload-animation" />
            
        </div>
        
    </div>

</MainGridLayout>
